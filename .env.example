# ══════════════════════════════════════════════════════════════════
# B4K Database — 환경변수 템플릿
# 복사: cp .env.example .env  →  실제 값으로 채운 뒤 사용
# 주의: .env 파일은 절대 git에 커밋하지 않는다
# ══════════════════════════════════════════════════════════════════

# ── Database (Supabase PostgreSQL) ────────────────────────────────
# Supabase 대시보드 → Settings → Database → Connection string
DB_HOST=aws-0-ap-southeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.your_project_ref
DB_PASSWORD=your_db_password

# ── Supabase API Keys ──────────────────────────────────────────────
# Supabase 대시보드 → Settings → API
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key   # 서버사이드 전용, 절대 클라이언트 노출 금지

# ── TourAPI (한국관광공사 공공데이터포털) ─────────────────────────
# https://api.data.go.kr → 한국관광공사_국문 관광정보 서비스
TOURAPI_KEY=your_tourapi_key

# ── MOIS (행정안전부 공공데이터포털) ──────────────────────────────
# https://www.data.go.kr → 행정안전부 사업자 데이터
MOIS_API_KEY=your_mois_api_key

# ── 번역 API ──────────────────────────────────────────────────────
# Google Gemini (en, ja, th, pt-BR 번역)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# DeepSeek (zh-CN, zh-TW 번역) — OpenAI 호환 API
# https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key

# 주소정보누리집 (도로명 주소 한→영 번역)
# https://business.juso.go.kr/addrlink/devAddrLinkRequestGuide.do
JUSO_API_KEY=your_juso_api_key

# ── Cloudinary (이미지 CDN) ────────────────────────────────────────
# https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Auth (FastAPI JWT) ─────────────────────────────────────────────
# 32자 이상 랜덤 문자열 권장: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── 번역 파이프라인 설정 (선택 — 기본값 사용 가능) ─────────────────
TRANSLATION_BATCH_SIZE=500
TRANSLATION_TOKEN_BUDGET=24000
DEEPSEEK_MAX_WORKERS=10

# ── Dedup 임계값 (선택 — 기본값 사용 가능) ────────────────────────
DEDUP_AUTO_MERGE_THRESHOLD=0.92
DEDUP_REVIEW_THRESHOLD=0.82
DEDUP_SPATIAL_RADIUS_M=50

# ── 확장 예정 (미사용, 추후 활성화) ──────────────────────────────
# MCST_API_KEY=your_mcst_api_key          # 문화체육관광부 (adapters/mcst/ 구현 시)
# ANTHROPIC_API_KEY=your_anthropic_key    # AI 챗봇 서버 (별도 레포)
# OPENAI_API_KEY=your_openai_key          # 레거시 (etl/gpt_translator.py, 현재 미사용)
# SLACK_WEBHOOK_URL=your_slack_webhook    # 파이프라인 알림 (pipeline/scheduler/ 확장 시)
# SENTRY_DSN=your_sentry_dsn             # 에러 모니터링
